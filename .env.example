# ==========================================
# ENVIRONMENT VARIABLES FOR N8N AI SALES SYSTEM
# DO NOT COMMIT ACTUAL SECRETS TO REPOSITORY
# ==========================================

# 1. n8n Core Settings
# ------------------------------------------
N8N_HOST=n8n.yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.yourdomain.com/
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# 2. Database (PostgreSQL / Supabase for RAG)
# ------------------------------------------
# Used by pgvector for storing document embeddings
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_HOST=db.xxx.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=your_db_password_here

# 3. AI Providers
# ------------------------------------------
# Google Gemini (Used for Main Agents and Embeddings)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (Optional fallback / Whisper for STT)
OPENAI_API_KEY=your_openai_api_key

# 4. Integrations & Credentials
# ------------------------------------------
# WhatsApp API Provider (ChatApp or equivalent)
WHATSAPP_API_TOKEN=your_chatapp_bearer_token
WHATSAPP_INSTANCE_ID=your_instance_id

# Telegram Alerting (For Error/Manager notifications)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Google Service Account (For Google Sheets CRM)
# Mount the JSON file and provide the path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
